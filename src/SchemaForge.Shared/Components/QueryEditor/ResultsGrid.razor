@using SchemaForge.Core.Models
@using SchemaForge.Core.Services
@inject SchemaForge.Shared.Interop.FileInterop FileExport

<div class="sf-results-grid-wrapper">
    <div class="sf-results-action-bar">
        <button class="sf-btn sf-btn-sm" @onclick="CopyCsv" title="Copy as CSV to clipboard">
            Copy CSV
        </button>
        <button class="sf-btn sf-btn-sm" @onclick="DownloadCsv" title="Download as CSV file">
            Download CSV
        </button>
        <button class="sf-btn sf-btn-sm" @onclick="CopyInsert" title="Copy as INSERT statements to clipboard">
            Copy as INSERT
        </button>
    </div>

    <table class="sf-results-grid">
        <thead>
            <tr>
                <th class="sf-row-num">#</th>
                @foreach (var col in Result.Columns)
                {
                    <th>@col</th>
                }
            </tr>
        </thead>
        <tbody>
            @{
                var rowNum = 0;
            }
            @foreach (var row in Result.Rows)
            {
                rowNum++;
                <tr>
                    <td class="sf-row-num">@rowNum</td>
                    @foreach (var cell in row)
                    {
                        <td>
                            @if (cell == null)
                            {
                                <span class="sf-null">NULL</span>
                            }
                            else
                            {
                                @cell.ToString()
                            }
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public QueryResult Result { get; set; } = default!;
    [Parameter] public string TableName { get; set; } = "table";

    private async Task CopyCsv()
    {
        var csv = CsvExporter.ToCsv(Result);
        await FileExport.CopyToClipboardAsync(csv);
    }

    private async Task DownloadCsv()
    {
        var csv = CsvExporter.ToCsv(Result);
        await FileExport.DownloadCsvAsync($"query_results_{DateTime.Now:yyyyMMdd_HHmmss}.csv", csv);
    }

    private async Task CopyInsert()
    {
        var sql = CsvExporter.ToInsertStatements(Result, TableName);
        await FileExport.CopyToClipboardAsync(sql);
    }
}
