@using SchemaForge.Shared.Interop
@inject MonacoEditorInterop Monaco
@inject ISqlExecutionService SqlEngine
@inject SchemaState SchemaState
@inject QueryState QueryState
@implements IAsyncDisposable
@implements IDisposable

<div class="sf-query-editor">
    <div class="sf-query-tabs">
        @for (var i = 0; i < QueryState.Tabs.Count; i++)
        {
            var index = i;
            var tab = QueryState.Tabs[i];
            <button class="sf-query-tab @(index == QueryState.ActiveTabIndex ? "active" : "")"
                    @onclick="() => SwitchTab(index)">
                <span>@tab.Title</span>
                @if (QueryState.Tabs.Count > 1)
                {
                    <span class="sf-tab-close" @onclick="() => CloseTab(index)" @onclick:stopPropagation="true">x</span>
                }
            </button>
        }
        @if (QueryState.Tabs.Count < 20)
        {
            <button class="sf-query-tab sf-tab-add" @onclick="AddTab">+</button>
        }
    </div>

    @if (!_schemaApplied)
    {
        <div class="sf-apply-banner">
            <span>Schema has not been applied to the SQL sandbox.</span>
            <button class="sf-btn sf-btn-primary sf-btn-sm" @onclick="ApplySchema">Apply Schema Now</button>
        </div>
    }

    <div class="sf-query-editor-area">
        <div id="@EditorElementId" class="sf-monaco-container"></div>
    </div>

    <div class="sf-query-actions">
        <button class="sf-btn sf-btn-execute" @onclick="ExecuteQuery" disabled="@_isExecuting">
            @(_isExecuting ? "Running..." : "Execute (F5)")
        </button>
        <button class="sf-btn" @onclick="ApplySchema">Apply Schema</button>
        @if (_lastResult != null)
        {
            <span class="sf-query-status">
                @if (_lastResult.Success)
                {
                    <span class="sf-status-success">@_lastResult.Rows.Length rows in @(_lastResult.ExecutionTimeMs.ToString("F1"))ms</span>
                }
                else
                {
                    <span class="sf-status-error">Error</span>
                }
            </span>
        }
    </div>

    <div class="sf-query-results">
        @if (!string.IsNullOrEmpty(_applyMessage))
        {
            <div class="sf-results-message" style="color: var(--sf-success); font-weight: 500;">@_applyMessage</div>
        }
        else if (_lastResult != null)
        {
            @if (!_lastResult.Success)
            {
                <div class="sf-error-banner">@_lastResult.ErrorMessage</div>
            }
            else if (_lastResult.Columns.Length > 0)
            {
                <ResultsGrid Result="_lastResult" />
            }
            else if (_lastResult.RowsAffected > 0)
            {
                <div class="sf-results-message">@_lastResult.RowsAffected row(s) affected</div>
            }
            else
            {
                <div class="sf-results-message">Query executed successfully.</div>
            }
        }
        else
        {
            <div class="sf-results-empty">Execute a query to see results here.</div>
        }
    </div>
</div>

@code {
    private const string EditorElementId = "monaco-query-editor";

    private bool _initialized;
    private bool _isExecuting;
    private bool _schemaApplied;
    private string? _applyMessage;
    private QueryResult? _lastResult;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await Monaco.InitializeAsync();

        if (!SqlEngine.IsInitialized)
            await SqlEngine.InitializeAsync();

        Monaco.OnExecuteRequested += OnMonacoExecute;
        Monaco.OnContentChanged += OnMonacoContentChanged;
        SchemaState.OnChange += HandleSchemaChanged;
        QueryState.OnChange += StateHasChanged;

        _initialized = true;
        await EnsureEditorCreated();
        await UpdateCompletionItems();
    }

    private async Task EnsureEditorCreated()
    {
        if (!await Monaco.HasEditorAsync(EditorElementId))
        {
            await Monaco.CreateEditorAsync(EditorElementId, QueryState.ActiveTab.SqlContent);
        }

        await Monaco.SetContextAsync(EditorElementId, QueryState.ActiveTab.Id);
    }

    private async Task SwitchTab(int index)
    {
        if (index == QueryState.ActiveTabIndex)
            return;

        await SyncEditorToStateAsync();
        QueryState.SetActiveTab(index);
        _lastResult = QueryState.ActiveTab.LastResult;
        await ApplyActiveTabToEditorAsync();
    }

    private async Task AddTab()
    {
        await SyncEditorToStateAsync();
        QueryState.AddTab();
        _lastResult = QueryState.ActiveTab.LastResult;
        await ApplyActiveTabToEditorAsync();
    }

    private async Task CloseTab(int index)
    {
        await SyncEditorToStateAsync();
        QueryState.CloseTab(index);
        _lastResult = QueryState.ActiveTab.LastResult;
        await ApplyActiveTabToEditorAsync();
    }

    private async Task ExecuteQuery()
    {
        _isExecuting = true;
        _applyMessage = null;
        StateHasChanged();

        try
        {
            var sql = await Monaco.GetValueAsync(EditorElementId);
            var selected = await Monaco.GetSelectedTextAsync(EditorElementId);
            var queryToRun = string.IsNullOrWhiteSpace(selected) ? sql : selected;

            if (string.IsNullOrWhiteSpace(queryToRun))
            {
                _isExecuting = false;
                return;
            }

            QueryState.UpdateTabContent(QueryState.ActiveTabIndex, sql);

            var result = await SqlEngine.ExecuteAsync(queryToRun);
            _lastResult = result;
            QueryState.UpdateTabResult(QueryState.ActiveTabIndex, result);

            // Add to history
            QueryState.AddHistoryEntry(new QueryHistoryEntry
            {
                Sql = queryToRun,
                ExecutedAt = DateTime.UtcNow,
                ExecutionTimeMs = result.ExecutionTimeMs,
                RowCount = result.Rows.Length,
                Success = result.Success,
                ErrorMessage = result.ErrorMessage
            });
        }
        catch (Exception ex)
        {
            _lastResult = new QueryResult
            {
                Success = false,
                ErrorMessage = ex.Message,
                ExecutionTimeMs = 0
            };
        }
        finally
        {
            _isExecuting = false;
            StateHasChanged();
        }
    }

    private async Task OnMonacoExecute(string editorId, string sql)
    {
        if (editorId == EditorElementId)
        {
            await ExecuteQuery();
        }
    }

    private Task OnMonacoContentChanged(string editorId, string tabId, string sql)
    {
        if (editorId == EditorElementId && !string.IsNullOrEmpty(tabId))
            QueryState.UpdateTabContent(tabId, sql);

        return Task.CompletedTask;
    }

    private async Task ApplySchema()
    {
        // Sandbox always uses SQLite regardless of the selected DDL dialect
        var generator = new SchemaForge.Core.DdlGeneration.SqliteDdlGenerator();
        var ddl = generator.GenerateFullDdl(SchemaState.Document);

        if (string.IsNullOrWhiteSpace(ddl) || SchemaState.Document.Tables.Count == 0)
            return;

        // Reset and recreate
        await SqlEngine.ResetAsync();
        var result = await SqlEngine.ExecuteAsync(ddl);

        if (result.Success)
        {
            _schemaApplied = true;
            var tableCount = SchemaState.Document.Tables.Count;
            _applyMessage = $"Schema applied - {tableCount} tables created";
            _lastResult = null;
        }
        else
        {
            _applyMessage = null;
            _lastResult = result;
        }

        StateHasChanged();
    }

    private void HandleSchemaChanged()
    {
        _ = OnSchemaChangedAsync();
    }

    private async Task OnSchemaChangedAsync()
    {
        try
        {
            if (_initialized)
            {
                await UpdateCompletionItems();
            }
        }
        catch (Exception)
        {
            // Swallow JS interop exceptions during schema changes
        }
    }

    private async Task SyncEditorToStateAsync()
    {
        if (!_initialized || !await Monaco.HasEditorAsync(EditorElementId))
            return;

        var content = await Monaco.GetValueAsync(EditorElementId);
        QueryState.UpdateTabContent(QueryState.ActiveTabIndex, content);
    }

    private async Task ApplyActiveTabToEditorAsync()
    {
        if (!_initialized || !await Monaco.HasEditorAsync(EditorElementId))
            return;

        await Monaco.SetContextAsync(EditorElementId, QueryState.ActiveTab.Id);
        await Monaco.SetValueAsync(EditorElementId, QueryState.ActiveTab.SqlContent);
        await Monaco.FocusAsync(EditorElementId);
    }

    private async Task UpdateCompletionItems()
    {
        var tableNames = SchemaState.Document.Tables.Select(t => t.Name).ToArray();
        var tableColumns = SchemaState.Document.Tables.ToDictionary(
            t => t.Name,
            t => t.Columns.Select(c => c.Name).ToArray());

        await Monaco.SetCompletionItemsAsync(tableNames, tableColumns);
    }

    public void Dispose()
    {
        SchemaState.OnChange -= HandleSchemaChanged;
        QueryState.OnChange -= StateHasChanged;
    }

    public async ValueTask DisposeAsync()
    {
        Monaco.OnExecuteRequested -= OnMonacoExecute;
        Monaco.OnContentChanged -= OnMonacoContentChanged;
        await Monaco.DisposeEditorAsync(EditorElementId);
    }
}
