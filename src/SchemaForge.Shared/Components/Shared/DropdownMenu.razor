<div class="sf-dropdown @(IsOpen ? "open" : "")" @onfocusout="HandleFocusOut" tabindex="-1">
    <button class="sf-btn sf-btn-sm" @onclick="Toggle" @onclick:stopPropagation="true">@Label</button>
    @if (IsOpen)
    {
        <div class="sf-dropdown-menu" @onclick="Close">
            @ChildContent
        </div>
    }
</div>

@code {
    [Parameter] public string Label { get; set; } = "Menu";
    [Parameter] public RenderFragment? ChildContent { get; set; }

    private bool IsOpen;

    private void Toggle() => IsOpen = !IsOpen;
    private void Close() => IsOpen = false;
    private async Task HandleFocusOut()
    {
        await Task.Delay(150); // Allow click events on children to fire first
        IsOpen = false;
        StateHasChanged();
    }
}
