@if (Visible)
{
    <div class="sf-context-overlay" @onclick="Hide" @onkeydown="OnKeyDown" tabindex="-1">
        <div class="sf-context-menu" style="left: @(X)px; top: @(Y)px;" @onclick:stopPropagation="true">
            @ChildContent
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public double X { get; set; }
    [Parameter] public double Y { get; set; }
    [Parameter] public RenderFragment? ChildContent { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private void Hide() => OnClose.InvokeAsync();

    private void OnKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Escape") OnClose.InvokeAsync();
    }
}
