@using SchemaForge.Shared.Services
@inject SchemaState SchemaState
@inject AutoSaveService AutoSave
@implements IDisposable

<footer class="sf-statusbar">
    <div class="sf-statusbar-left">
        <span class="sf-status-pill">
            <span class="sf-status-dot"></span>
            @FormatDialect(SchemaState.Document.TargetDialect)
        </span>
        <span class="sf-status-pill @(AutoSave.SaveStatus == "Saved" ? "" : "sf-unsaved")">@AutoSave.SaveStatus</span>
    </div>
    <div class="sf-statusbar-center">
        <span class="sf-status-pill">@SchemaState.Document.Tables.Count tables</span>
        <span class="sf-status-pill">@SchemaState.Document.Tables.Sum(t => t.Columns.Count) columns</span>
        <span class="sf-status-pill">@SchemaState.Document.Relationships.Count relationships</span>
    </div>
    <div class="sf-statusbar-right">
        <span class="sf-status-pill">@((int)(SchemaState.Document.Canvas.Zoom * 100))% zoom</span>
    </div>
</footer>

@code {
    private Action<string>? _onSaveStatusChanged;

    protected override void OnInitialized()
    {
        SchemaState.OnChange += StateHasChanged;
        _onSaveStatusChanged = _ => InvokeAsync(StateHasChanged);
        AutoSave.OnSaveStatusChanged += _onSaveStatusChanged;
    }

    public void Dispose()
    {
        SchemaState.OnChange -= StateHasChanged;
        if (_onSaveStatusChanged != null)
            AutoSave.OnSaveStatusChanged -= _onSaveStatusChanged;
    }

    private static string FormatDialect(SqlDialect dialect) => dialect switch
    {
        SqlDialect.SQLite => "SQLite",
        SqlDialect.PostgreSQL => "PostgreSQL",
        SqlDialect.MySQL => "MySQL",
        SqlDialect.SqlServer => "SQL Server",
        _ => dialect.ToString()
    };
}
