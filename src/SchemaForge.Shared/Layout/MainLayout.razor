@inherits Microsoft.AspNetCore.Components.LayoutComponentBase
@using SchemaForge.Shared.Interop
@using SchemaForge.Shared.Services
@inject SchemaState SchemaState
@inject KeyboardInterop Keyboard
@inject AutoSaveService AutoSave
@inject NavigationManager Nav
@implements IDisposable

<div class="sf-app" role="application" aria-label="SchemaForge">
    <div class="sf-small-screen-banner">SchemaForge works best on a wider screen. Design mode is optimized for 960px and up.</div>
    <TopBar IsDesignMode="@_isDesignMode" IsDesignModeChanged="SetMode" OnNavigateHome="GoHome" />
    <div class="sf-body @(IsDesignerRoute ? "sf-body-workspace" : "sf-body-page")" role="main">
        <CascadingValue Value="@_isDesignMode" Name="IsDesignMode">
            @Body
        </CascadingValue>
    </div>
    <StatusBar />
</div>

@code {
    private bool _isDesignMode = true;
    private bool IsDesignerRoute => Nav.ToBaseRelativePath(Nav.Uri).StartsWith("designer", StringComparison.OrdinalIgnoreCase);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Keyboard.InitializeAsync();
            Keyboard.OnShortcut += HandleShortcut;
            Nav.LocationChanged += HandleLocationChanged;
        }
    }

    private void HandleLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetMode(bool isDesign)
    {
        _isDesignMode = isDesign;
        StateHasChanged();
    }

    private void HandleShortcut(string shortcut)
    {
        _ = HandleShortcutAsync(shortcut);
    }

    private async Task HandleShortcutAsync(string shortcut)
    {
        try
        {
            switch (shortcut)
            {
                case "Ctrl+1":
                    _isDesignMode = true;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "Ctrl+2":
                    _isDesignMode = false;
                    await InvokeAsync(StateHasChanged);
                    break;
                case "Ctrl+S":
                    await AutoSave.SaveNowAsync();
                    break;
                case "Ctrl+Z":
                    SchemaState.Undo();
                    break;
                case "Ctrl+Y":
                    SchemaState.Redo();
                    break;
                case "Ctrl+T":
                    var tableCount = SchemaState.Document.Tables.Count;
                    SchemaState.Dispatch(new AddTableAction(new SchemaForge.Core.Models.TableDefinition
                    {
                        Name = $"table_{tableCount + 1}",
                        Columns = [new SchemaForge.Core.Models.ColumnDefinition
                        {
                            Name = "id",
                            DataType = SchemaForge.Core.Models.LogicalDataType.Integer,
                            IsPrimaryKey = true,
                            IsAutoIncrement = true,
                            IsNullable = false
                        }]
                    }));
                    await InvokeAsync(StateHasChanged);
                    break;
            }
        }
        catch (Exception)
        {
            // Swallow JS interop exceptions during shortcuts
        }
    }

    private async Task GoHome()
    {
        if (AutoSave.SaveStatus == "Unsaved changes")
        {
            await AutoSave.SaveNowAsync();
        }
        Nav.NavigateTo("/home");
    }

    public void Dispose()
    {
        Keyboard.OnShortcut -= HandleShortcut;
        Nav.LocationChanged -= HandleLocationChanged;
    }
}
