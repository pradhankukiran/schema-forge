@using SchemaForge.Shared.Interop
@using SchemaForge.Core.DdlGeneration
@inject SchemaState SchemaState
@inject DdlGeneratorFactory DdlFactory
@inject FileInterop FileExport
@inject CanvasExportInterop CanvasExport

<header class="sf-topbar">
    <div class="sf-topbar-left">
        <span class="sf-logo">SchemaForge</span>
    </div>
    <div class="sf-topbar-center">
        <button class="sf-mode-tab @(IsDesignMode ? "active" : "")" @onclick="() => IsDesignModeChanged.InvokeAsync(true)">
            Design
        </button>
        <button class="sf-mode-tab @(!IsDesignMode ? "active" : "")" @onclick="() => IsDesignModeChanged.InvokeAsync(false)">
            Query
        </button>
    </div>
    <div class="sf-topbar-right">
        <DialectSelector />
        <button class="sf-btn sf-btn-sm" @onclick="() => _showImport = true">Import</button>
        <DropdownMenu Label="Export">
            <button class="sf-dropdown-item" @onclick="ExportSql">SQL (@FormatDialect(SchemaState.Document.TargetDialect))</button>
            <div class="sf-dropdown-sep"></div>
            <button class="sf-dropdown-item" @onclick="ExportPng">PNG (2x)</button>
            <button class="sf-dropdown-item" @onclick="ExportSvg">SVG</button>
        </DropdownMenu>
        <button class="sf-btn sf-btn-sm" @onclick="() => OnNavigateHome.InvokeAsync()">Home</button>
    </div>
</header>

<ImportDdlDialog IsOpen="_showImport" OnClose="() => _showImport = false" />

@code {
    [Parameter] public bool IsDesignMode { get; set; } = true;
    [Parameter] public EventCallback<bool> IsDesignModeChanged { get; set; }
    [Parameter] public EventCallback OnNavigateHome { get; set; }

    private bool _showImport;

    private async Task ExportSql()
    {
        if (SchemaState.Document.Tables.Count == 0) return;
        var dialect = SchemaState.Document.TargetDialect;
        var generator = DdlFactory.GetGenerator(dialect);
        var ddl = generator.GenerateFullDdl(SchemaState.Document);
        var filename = $"{SchemaState.Document.Name.Replace(" ", "_").ToLowerInvariant()}_{dialect.ToString().ToLowerInvariant()}.sql";
        await FileExport.DownloadSqlAsync(filename, ddl);
    }

    private async Task ExportPng()
    {
        var name = SchemaState.Document.Name.Replace(" ", "_").ToLowerInvariant();
        await CanvasExport.DownloadPngAsync($"{name}.png");
    }

    private async Task ExportSvg()
    {
        var name = SchemaState.Document.Name.Replace(" ", "_").ToLowerInvariant();
        await CanvasExport.DownloadSvgAsync($"{name}.svg");
    }

    private static string FormatDialect(SqlDialect d) => d switch
    {
        SqlDialect.SQLite => "SQLite",
        SqlDialect.PostgreSQL => "PostgreSQL",
        SqlDialect.MySQL => "MySQL",
        SqlDialect.SqlServer => "SQL Server",
        _ => d.ToString()
    };
}
